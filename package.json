{
  "name": "pothos-drizzle-generator",
  "version": "0.2.0",
  "main": "./dist/cjs/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p ./tsconfig.esm.json && cpy esm dist",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src ./test",
    "test:actions": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "test:docker": "docker compose -f test/docker/docker-compose.yml up -d",
    "test:generate": "drizzle-kit generate --config test/drizzle.config.ts",
    "test:migrate": "drizzle-kit migrate --config test/drizzle.config.ts",
    "test:seed": "tsx test/tools/seed",
    "test:reset": "tsx test/tools/reset && pnpm run test:migrate",
    "explorer": "tsx --watch test/tools/explorer",
    "update:drizzle": "pnpm install -D drizzle-orm@rc drizzle-kit@rc drizzle-seed@rc"
  },
  "dependencies": {
    "graphql": "^16.14.0",
    "graphql-scalars": "^1.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/graphql-server": "^0.7.0",
    "@hono/node-server": "2.0.3",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-drizzle": "^0.17.4",
    "@types/graphql": "^14.5.0",
    "@urql/core": "6.0.1",
    "@vitest/coverage-v8": "4.1.7",
    "apollo-explorer": "1.1.3",
    "cpy-cli": "^7.0.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "1.0.0-rc.3",
    "drizzle-orm": "1.0.0-rc.3",
    "drizzle-seed": "1.0.0-rc.3",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "graphql-auto-query": "1.1.1",
    "hono": "^4.12.22",
    "jose": "6.2.3",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "4.1.7"
  },
  "repository": "https://github.com/node-libraries/pothos-drizzle-generator",
  "author": "SoraKumo <info@croud.jp>",
  "license": "MIT"
}
